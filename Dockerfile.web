# Kunatra web — Next.js. NEXT_PUBLIC_API_BASE is baked at build time (client-side),
# so it must be a URL the browser can reach (the published API port on the host).
FROM node:22-slim

WORKDIR /repo

COPY package.json package-lock.json ./
COPY packages/engine/package.json packages/engine/
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
RUN npm install

COPY . .
RUN npm run build -w @atlas/engine

ARG NEXT_PUBLIC_API_BASE=http://localhost:4100
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE
RUN npm run build -w @atlas/web

ENV NODE_ENV=production
EXPOSE 3000

# Serve the built app on all interfaces so the host can reach it.
CMD ["node", "node_modules/next/dist/bin/next", "start", "apps/web", "-H", "0.0.0.0", "-p", "3000"]

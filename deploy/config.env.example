# Copy to config.env and adjust. config.env is gitignored (holds the DB password
# and resolved endpoints). All scripts source it via lib.sh.

# --- AWS ---
AWS_PROFILE=kunatra
AWS_REGION=us-east-1
PROJECT=kunatra

# --- RDS (free-tier: db.t4g.micro, 20 GB, single-AZ) ---
DB_INSTANCE_ID=kunatra-db
DB_NAME=kunatra
DB_USER=kunatra
DB_PASSWORD=                       # leave blank → 10-rds.sh generates a strong one and writes it back here
DB_INSTANCE_CLASS=db.t4g.micro     # free-tier eligible
DB_STORAGE_GB=20
DB_ENGINE_VERSION=16
DB_SG_NAME=kunatra-db-sg
DB_HOST=                           # filled in by 10-rds.sh once the instance is available

# Lightsail's managed VPC peers with your default AWS VPC so the API can reach RDS
# privately. This CIDR is fixed per region; us-east-1 = 172.26.0.0/16.
LIGHTSAIL_CIDR=172.26.0.0/16

# --- Lightsail Container Service (API) ---
LS_SERVICE=kunatra-api
LS_POWER=nano                      # nano=$7/mo · micro=$10/mo · small=$20/mo
LS_SCALE=1

# --- S3 static web + CloudFront ---
WEB_BUCKET=                        # globally-unique, e.g. kunatra-web-<accountid>; 50-web-s3.sh defaults it
CF_DIST_ID=                        # filled in by 60-cloudfront.sh
PUBLIC_URL=                        # filled in by 60-cloudfront.sh (the CloudFront domain)

# --- App secrets (generated by 40-lightsail-api.sh if blank) ---
AUTH_SECRET=
FIELD_ENCRYPTION_KEY=
